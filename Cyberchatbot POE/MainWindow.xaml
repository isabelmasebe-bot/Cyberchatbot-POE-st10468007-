<Window x:Class="Cyberchatbot_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cyberchatbot_POE"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Chat Area -->
            <RowDefinition Height="Auto"/>
            <!-- Quick Action Buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Input Area -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="Beige" Padding="12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🛡️ Cybersecurity Awareness Bot" 
                   Foreground="DarkRed" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   VerticalAlignment="Center"/>
                <TextBlock Text=" (Type 'help' for commands)" 
                   Foreground="Green" 
                   Margin="20,0,0,0" 
                   VerticalAlignment="Center" 
                   Opacity="0.8"/>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <ScrollViewer Grid.Row="1" Margin="10" Background="#F5F5DC" 
              VerticalScrollBarVisibility="Auto" x:Name="ChatScroll">
            <StackPanel x:Name="ChatPanel" Margin="5"/>
        </ScrollViewer>

        <!-- Quick Action Buttons -->
        <Border Grid.Row="2" Background="Beige" BorderBrush="DarkRed" BorderThickness="5" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="🚀 Start Quiz" 
                Click="StartQuizButton_Click"
                Width="140" Height="40" Margin="8"
                Background="DarkRed" Foreground="White" 
                FontWeight="Bold" FontSize="14"/>

                <Button Content="📋 View Tasks" 
                Click="ViewTasksButton_Click"
                Width="140" Height="40" Margin="8"
                Background="DarkRed" Foreground="White" 
                FontWeight="Bold" FontSize="14"/>

                <Button Content="📜 Show Activity Log" 
                Click="ShowLogButton_Click"
                Width="160" Height="40" Margin="8"
                Background="DarkRed" Foreground="White" 
                FontWeight="Bold" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Grid Grid.Row="3"  Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox" 
             KeyDown="InputBox_KeyDown" 
             Background="Beige" 
             Foreground="SaddleBrown" 
             Padding="12" 
             FontSize="15"
             Margin="0,0,10,0"
             VerticalContentAlignment="Center"
             Height="45"/>

            <Button Grid.Column="1" Content="Send" 
            Click="SendButton_Click" 
            Width="85" Height="45" 
            Background="DarkRed" Foreground="White" 
            FontWeight="Bold" FontSize="14"/>

            <Button Grid.Column="2" Content="🎤" 
            Click="VoiceButton_Click" 
            Width="55" Height="45" 
            Margin="8,0,0,0"
            Background="DarkRed" Foreground="Beige" 
            FontSize="18"/>
        </Grid>


    </Grid>
</Window>
